<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/primary_color"
    android:gravity="center"
    android:padding="24dp">

    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_fingerprint"
        android:contentDescription="Fingerprint"
        android:tint="@color/white"
        android:layout_marginBottom="32dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Parmak İzi ile Giriş"
        android:textSize="24sp"
        android:textColor="@color/white"
        android:fontFamily="@font/roboto_bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lütfen parmak izinizi okuyucuya dokundur"
        android:textSize="14sp"
        android:textColor="@color/white"
        android:alpha="0.8"
        android:layout_marginBottom="48dp"
        android:textAlignment="center" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginBottom="48dp" />

    <Button
        android:id="@+id/retryButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tekrar Dene"
        android:backgroundTint="@color/accent_color"
        android:textColor="@color/white"
        android:padding="14dp"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/usePasswordButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Şifre ile Giriş Yap"
        android:backgroundTint="@color/white"
        android:textColor="@color/primary_color"
        android:padding="14dp" />

</LinearLayout>