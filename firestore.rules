rule_version = '1'
rules {
  match {database} /users/{userId} {
    allow read: if request.auth.uid == userId;
    allow write: if request.auth.uid == userId;
  }
  
  match {database} /suspicious_plates/{plateId} {
    allow read: if request.auth != null;
    allow write: if request.auth.token.isAdmin == true;
  }
  
  match {database} /detections/{detectionId} {
    allow read: if request.auth != null && (request.auth.uid == resource.data.userId || request.auth.token.isAdmin == true);
    allow write: if request.auth != null;
  }
}