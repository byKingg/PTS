{
  "rules": {
    "users": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid"
      }
    },
    "suspiciousPlates": {
      ".read": "auth != null",
      ".write": "root.child('users').child(auth.uid).child('isAdmin').val() === true"
    },
    "detections": {
      "$detectionId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    }
  }
}